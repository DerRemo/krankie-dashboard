<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.krankie.dashboard</string>
  <key>ProgramArguments</key>
  <array>
    <string>__BIN__</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>WorkingDirectory</key>
  <string>__CWD__</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PORT</key><string>3737</string>
    <key>LOG_LEVEL</key><string>info</string>
    <key>KRANKIE_DB</key><string>__KRANKIE_DB__</string>
    <key>KRANKIE_BIN</key><string>__KRANKIE_BIN__</string>
    <key>HOME</key><string>__HOME__</string>
    <key>PATH</key><string>__PATH__</string>
  </dict>
  <key>StandardOutPath</key>
  <string>__HOME__/Library/Logs/krankie-dashboard/stdout.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/Library/Logs/krankie-dashboard/stderr.log</string>
</dict>
</plist>
